import express from "express"
import cors from "cors"
import dotenv from "dotenv"
import OpenAI from "openai"
import fetch from "node-fetch"

dotenv.config()

const app = express()
const port = process.env.PORT || 3000

app.use(cors())
app.use(express.json({ limit: "1mb" }))

const client = new OpenAI({
  apiKey: process.env.OPENAI_API_KEY
})

/* -------------------------------
PAGINA MATCHING
--------------------------------*/

const PAGES = [
  { url: "https://www.ajhomedesign.nl/voorraad", keywords: ["voorraad", "beschikbaar"] },
  { url: "https://www.ajhomedesign.nl/kozijnen", keywords: ["kozijn", "kozijnen"] },
  { url: "https://www.ajhomedesign.nl/rolluiken/screens", keywords: ["screen", "screens"] },
  { url: "https://www.ajhomedesign.nl/deuren", keywords: ["deur", "deuren"] },
  { url: "https://www.ajhomedesign.nl/veranda-s", keywords: ["veranda", "pergola", "serre"] },
  { url: "https://www.ajhomedesign.nl/horren", keywords: ["hor", "horren"] }
]

function findRelevantPage(text) {
  const lower = text.toLowerCase()

  for (const page of PAGES) {
    if (page.keywords.some(k => lower.includes(k))) {
      return page.url
    }
  }

  return "https://www.ajhomedesign.nl/"
}

/* -------------------------------
HTML OPSCHONEN
--------------------------------*/

function cleanHtml(html) {
  return html
    .replace(/<script[\s\S]*?>[\s\S]*?<\/script>/gi, "")
    .replace(/<style[\s\S]*?>[\s\S]*?<\/style>/gi, "")
    .replace(/<[^>]+>/g, " ")
    .replace(/\s+/g, " ")
    .slice(0, 4000) // limiet zodat het snel blijft
}

/* -------------------------------
ROUTES
--------------------------------*/

app.get("/", (req, res) => {
  res.send("Chat server draait")
})

app.post("/api/chat-site", async (req, res) => {
  try {

    const {
      message = "",
      messages = []
    } = req.body || {}

    const conversationText = messages
      .slice(-10)
      .map(m => `${m.role}: ${m.content}`)
      .join("\n")

    /* -------------------------------
    PAGINA OPHALEN
    --------------------------------*/

    const pageUrl = findRelevantPage(message)

    let pageContent = ""

    try {
      const html = await fetch(pageUrl).then(r => r.text())
      pageContent = cleanHtml(html)
    } catch (err) {
      console.log("Pagina ophalen mislukt")
    }

    /* -------------------------------
    OPENAI CALL
    --------------------------------*/

    const response = await client.responses.create({
      model: "gpt-5.4",
      input: [
        {
          role: "system",
          content: `Je bent de chatbot van AJ Home Design.

Gebruik ALLEEN informatie die:
- in de website content staat
- of in de bedrijfsregels zit

Gebruik de website content als primaire bron.

Als iets niet duidelijk in de content staat:
- gebruik de fallback
- verzin niets

Houd antwoorden kort en duidelijk.`
        },
        {
          role: "user",
          content: `
Website pagina:
${pageUrl}

Website inhoud:
${pageContent}

Vorige chat:
${conversationText}

Vraag:
${message}
`
        }
      ]
    })

    res.json({
      reply: response.output_text || "Geen antwoord"
    })

  } catch (error) {

    console.error(error)

    res.status(500).json({
      reply: "Er ging iets mis op de server"
    })

  }
})

app.listen(port, () => {
  console.log(`Server draait op poort ${port}`)
})
